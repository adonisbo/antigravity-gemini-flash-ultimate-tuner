# Git attributes for Antigravity Ultimate Tuner
# Ensure PowerShell scripts are checked out with BOM preserved

# Force LF line endings for shell scripts
*.sh text eol=lf

# PowerShell scripts: preserve BOM, use CRLF on Windows
*.ps1 text eol=crlf working-tree-encoding=UTF-8

# Batch files: CRLF
*.bat text eol=crlf

# Markdown: LF
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
